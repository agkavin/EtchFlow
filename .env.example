# ─────────────────────────────────────────────────────────────────────────────
# .env.example — EtchFlow MVP Configuration
# Copy to .env for local development without Docker:
#   cp .env.example .env
#
# When running via Docker Compose, environment variables are passed directly
# through docker-compose.yml — .env is not required.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# Full Postgres DSN. Service fails to start if this is missing.
DATABASE_URL=postgres://etchflow:etchflow@localhost:5432/etchflow?sslmode=disable

# Max connections in pgxpool.
DB_POOL_MAX_CONNS=10

# ── Server ────────────────────────────────────────────────────────────────────
HTTP_PORT=8080

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
# json (production) | console (development, coloured)
LOG_FORMAT=console
